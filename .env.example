# --- Discord ---
# Token del bot (Discord Developer Portal > tu app > Bot > Reset Token)
DISCORD_TOKEN=
# Application ID (Developer Portal > General Information > Application ID)
DISCORD_APP_ID=
# (Opcional) limita a un solo servidor mientras pruebas
DISCORD_GUILD_ID=

# --- OpenAI ---
OPENAI_API_KEY=
# Modelo para el "cerebro" de Samara (sus respuestas)
OPENAI_MODEL=gpt-4o
# Modelo barato para decidir "¿me meto en esta conversación?"
OPENAI_DECISION_MODEL=gpt-4o-mini
# Modelo de embeddings (memoria de largo plazo)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Comportamiento ---
# Cuántos mensajes recientes mantiene en memoria de trabajo por canal
SHORT_TERM_WINDOW=20
# Cuántos mensajes de otros deben pasar tras hablar ella para volver a meterse
# sola SIN que le hablen directo (evita responder en cadena en grupo).
# No aplica si el mensaje va dirigido a ella: ahí siempre contesta.
AMBIENT_MIN_GAP=1
# Iniciativa propia: si un canal queda en silencio entre MIN y MAX segundos
# (tiempo al azar, para que sea esporádico), Samara considera romper el
# silencio / hacer plática. Pon PROACTIVE_IDLE_MAX_SEC=0 para desactivarlo.
PROACTIVE_IDLE_MIN_SEC=60
PROACTIVE_IDLE_MAX_SEC=240
# Reflexión: cada cuántas interacciones Samara "repasa" lo vivido y saca
# conclusiones/opiniones propias (sobre la gente y los temas) que guarda como
# recuerdos. Esas opiniones luego afloran cuando habla. 0 = desactivado.
REFLECTION_EVERY=12
