# --- Discord ---
# Token del bot (Discord Developer Portal > tu app > Bot > Reset Token)
DISCORD_TOKEN=
# Application ID (Developer Portal > General Information > Application ID)
DISCORD_APP_ID=
# (Opcional) limita a un solo servidor mientras pruebas
DISCORD_GUILD_ID=
# Desarrollador: con él Samara es franca y no se niega a preguntas técnicas.
# Lo más fácil: tu nombre visible o usuario de Discord.
DEV_USER_NAME=
# Alternativa más fiable: tu ID numérico (Modo Desarrollador > Copiar ID).
DEV_USER_ID=

# --- OpenAI ---
OPENAI_API_KEY=
# Modelo del "cerebro" de Samara (sus respuestas).
# Opciones (verifica el nombre exacto y tu acceso en platform.openai.com):
#   gpt-5.4   -> recomendado, buen equilibrio calidad/costo
#   gpt-5.5   -> máxima calidad, más caro
#   gpt-4o    -> alternativa más barata y rápida
OPENAI_MODEL=gpt-5.4
# Modelo barato para decidir "¿me meto?" (rápido y económico)
OPENAI_DECISION_MODEL=gpt-5.4-mini
# Modelo de embeddings (memoria de largo plazo)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Comportamiento ---
# Cuántos mensajes recientes mantiene en memoria de trabajo por canal
SHORT_TERM_WINDOW=40
# Cuántos mensajes de otros deben pasar tras hablar ella para volver a meterse
# sola SIN que le hablen directo (evita responder en cadena en grupo).
# No aplica si el mensaje va dirigido a ella: ahí siempre contesta.
AMBIENT_MIN_GAP=1
# Iniciativa propia: si un canal queda en silencio entre MIN y MAX segundos
# (tiempo al azar, para que sea esporádico), Samara considera romper el
# silencio / hacer plática. Pon PROACTIVE_IDLE_MAX_SEC=0 para desactivarlo.
PROACTIVE_IDLE_MIN_SEC=60
PROACTIVE_IDLE_MAX_SEC=240
# Reflexión: cada cuántas interacciones Samara "repasa" lo vivido y saca
# conclusiones/opiniones propias (sobre la gente y los temas) que guarda como
# recuerdos. Esas opiniones luego afloran cuando habla. 0 = desactivado.
REFLECTION_EVERY=12
# Olvido: al reflexionar, conserva los N recuerdos episódicos más recientes y
# olvida los viejos que sobran (lo importante ya quedó en sus reflexiones, que
# nunca se borran). Umbral alto: solo poda cuando ya tiene muchísimos.
# 0 = no olvidar nunca.
MEMORY_KEEP_EPISODIC=5000
# Log de depuración: registra acciones internas (percepción, recall, tools,
# apreciación, reflexión, respuesta) en data/debug.jsonl. Velo con: npm run debug
DEBUG_LOG=false
# Estilo "chat real": minúsculas, sin acentos/puntos/signos de apertura.
# Pon CASUAL_STYLE=false para que escriba con ortografía normal.
CASUAL_STYLE=true
